APP_NAME=parcelpilot-tracking
DATABASE_PATH=backend/data/tracking.sqlite3
SHOPIFY_APP_SECRET=replace_me
SHOPIFY_CLIENT_ID=replace_me
SHOPIFY_CLIENT_SECRET=replace_me
SHOPIFY_STORE_SLUG=your-store
SHOPIFY_STOREFRONT_URL=https://your-store.example.com
SHOPIFY_ADMIN_ACCESS_TOKEN=replace_me
SHOPIFY_ADMIN_API_VERSION=2026-04
ALLOWED_SHOP_DOMAINS=your-store.myshopify.com
SHOPIFY_PROXY_PREFIX=/apps/track/api/track
SEVENTEEN_TRACK_API_KEY=replace_me
SEVENTEEN_TRACK_SHOPIFY_URL=https://shopify.17track.net/trackcenterapi/call
SEVENTEEN_TRACK_SHOPIFY_TRACKING_URL=https://shopify-t.17track.net/track/shopify
REQUIRE_ORDER_TRACKING_MATCH=true
BYPASS_PROXY_SIGNATURE=true
MOCK_WHEN_API_KEY_MISSING=true
IP_LIMIT_PER_MINUTE=5
IP_LIMIT_PER_DAY=50
TRACKING_REFRESH_WINDOW_SECONDS=300
TRACKING_REFRESH_LIMIT=3
CACHE_TTL_ACTIVE_MINUTES=120
CACHE_TTL_DELIVERED_HOURS=72
CACHE_TTL_NOT_FOUND_HOURS=6
CACHE_TTL_EXCEPTION_MINUTES=60
HMAC_MAX_AGE_SECONDS=300
INTERNAL_DASHBOARD_TOKEN=replace_me
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
ALERT_MIN_INTERVAL_SECONDS=900
ALERT_SPIKE_WINDOW_SECONDS=300
ALERT_RATE_LIMIT_SPIKE_THRESHOLD=8
ALERT_PROXY_FAILURE_SPIKE_THRESHOLD=5
ALERT_NOT_STORE_ORDER_SPIKE_THRESHOLD=8
