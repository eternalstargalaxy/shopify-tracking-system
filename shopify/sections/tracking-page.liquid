{{ 'tracking.css' | asset_url | stylesheet_tag }}

<section class="tracking-page" data-section-id="{{ section.id }}">
  <script>
    window.TRACKING_CONFIG = {
      apiEndpoint: {{ section.settings.proxy_path | json }},
      demoMode: false
    };
  </script>

  <div class="tracking-shell">
    <div class="tracking-header">
      <h1>{{ section.settings.heading }}</h1>
    </div>

    <div class="tracking-layout">
      <form id="trackingForm" class="tracking-query" novalidate>
        <div class="tracking-intro">
          <p class="tracking-copy">Enter your tracking number to view the latest shipping progress.</p>
        </div>

        <label class="tracking-field">
          <span>Tracking number</span>
          <input
            id="trackingNumbers"
            name="trackingNumbers"
            spellcheck="false"
            placeholder="Enter your tracking number"
            type="text"
            inputmode="text"
            autocomplete="off"
          >
        </label>

        <div class="tracking-actions">
          <button type="submit" id="trackBtn" class="tracking-button">Track parcel</button>
        </div>

        <p id="formMessage" class="tracking-message" role="status" aria-live="polite"></p>
      </form>

      <section class="tracking-result">
        <div class="tracking-empty" id="emptyState">
          Enter a tracking number to view the latest delivery timeline.
        </div>
        <div class="tracking-result-list" id="resultsList"></div>
      </section>
    </div>
  </div>
</section>

<template id="shipmentTemplate">
  <article class="shipment-card">
    <p class="shipment-summary-line"></p>

    <section class="info-panel tracking-info-panel">
      <div class="panel-heading">
        <h2>Tracking Information</h2>
      </div>

      <div class="shipment-head">
        <div class="shipment-head-main">
          <span class="carrier-name"></span>
          <h3 class="tracking-number"></h3>
        </div>
        <div class="last-mile-card" hidden>
          <span>Last-mile carrier</span>
          <strong class="last-mile-tracking-number"></strong>
        </div>
      </div>

      <div class="shipment-meta">
        <div>
          <span>Dispatched</span>
          <strong class="dispatched-at"></strong>
        </div>
        <div>
          <span>Destination</span>
          <strong class="destination"></strong>
        </div>
      </div>

      <div class="shipment-highlights">
        <div>
          <span>Current stage</span>
          <strong class="status-detail"></strong>
        </div>
        <div>
          <span>Last update</span>
          <strong class="updated-at-secondary"></strong>
        </div>
        <div>
          <span>Timeline</span>
          <strong class="event-count"></strong>
        </div>
      </div>

      <p class="support-notice"></p>

      <div class="shipment-progress" aria-hidden="true">
        <span data-step="info_received"></span>
        <span data-step="in_transit"></span>
        <span data-step="out_for_delivery"></span>
        <span data-step="delivered"></span>
      </div>

      <p class="provider-status"></p>

      <ol class="timeline"></ol>
      <button type="button" class="timeline-toggle" hidden></button>
    </section>

    <section class="info-panel order-summary-panel" hidden>
      <div class="panel-heading">
        <h2>Order Information</h2>
      </div>
      <div class="order-summary" hidden>
        <div class="order-name-block">
          <span>Order</span>
          <strong class="order-name"></strong>
        </div>
        <div class="order-placed-block">
          <span>Placed</span>
          <strong class="order-placed-at"></strong>
        </div>
        <div class="order-fulfilment-block">
          <span>Fulfilment</span>
          <strong class="order-fulfilment-status"></strong>
        </div>
        <div class="order-items-block">
          <div class="order-items-grid"></div>
        </div>
      </div>
    </section>
  </article>
</template>

{{ 'tracking.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Tracking page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Track your order"
    },
    {
      "type": "text",
      "id": "proxy_path",
      "label": "App proxy path",
      "default": "/apps/track/api/track"
    }
  ]
}
{% endschema %}
